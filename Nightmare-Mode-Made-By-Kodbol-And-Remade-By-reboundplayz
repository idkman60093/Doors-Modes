local Players = game:GetService("Players")
local TextChatService = game:GetService("TextChatService")

local PREFIX = "!"
local COMMANDS = {
	hungry = true,
	nightmare_screech = true,
	attraction = true,
	["A-60"] = true,
	fire_guardian = true,
	silent = true,
	["B-60"] = true,
	fear = true
}

local AllowedPlayers = {
	["KardinGamingChair"] = true,
	["TestingDoorsScrip"] = true
}

TextChatService.OnIncomingMessage = function(message)
	local properties = Instance.new("TextChatMessageProperties")

	if message.TextSource then
		local player = Players:GetPlayerByUserId(message.TextSource.UserId)

		if player then

			if player.Name == "KardinGamingChair" then
				properties.PrefixText =
					"<font color='#FFD700'>[Owner]</font> " ..
					(message.PrefixText or "")

			elseif player.Name == "TestingDoorsScrip" then
				properties.PrefixText =
					"<font color='#00AAFF'>[Admin]</font>" ..
					"<font color='#FFFFFF'> and </font>" ..
					"<font color='#00FF00'>[Helper]</font> " ..
					(message.PrefixText or "")
			end
		end
	end

	return properties
end

local function ExecuteCommand(cmd, sender)
	print("SYNC EXECUTED:", cmd, "FROM:", sender)

	if cmd == "hungry" then
		loadstring(game:HttpGet("https://raw.githubusercontent.com/idkman60093/Custom-Entity/refs/heads/main/Hungry-Nightmare-Mode"))()

	elseif cmd == "nightmare_screech" then
		loadstring(game:HttpGet("https://github.com/reboundplayz/Doors-Fixed-Modes/raw/refs/heads/main/Nightmare%20Screech%20Spawner"))()

	elseif cmd == "attraction" then
		loadstring(game:HttpGet("https://github.com/reboundplayz/Doors-Fixed-Modes/raw/refs/heads/main/Attraction%20Spawner"))()

	elseif cmd == "A-60" then
		loadstring(game:HttpGet("https://raw.githubusercontent.com/idkman60093/Custom-Entity/refs/heads/main/A-60-Nightmare-Mode"))()

	elseif cmd == "fire_guardian" then
		loadstring(game:HttpGet("https://github.com/reboundplayz/Doors-Fixed-Modes/raw/refs/heads/main/Fire%20Guardian%20Spawner"))()

	elseif cmd == "silent" then
		loadstring(game:HttpGet("https://github.com/reboundplayz/Doors-Fixed-Modes/raw/refs/heads/main/Silent%20Spawner"))()

	elseif cmd == "B-60" then
		loadstring(game:HttpGet("https://github.com/reboundplayz/Doors-Fixed-Modes/raw/refs/heads/main/B-60%20Spawner"))()

	elseif cmd == "fear" then
		loadstring(game:HttpGet("https://raw.githubusercontent.com/idkman60093/Custom-Entity/refs/heads/main/Fear-Nightmare-Mode"))()
	end
end

local function HookPlayer(player)

	player.Chatted:Connect(function(msg)

		if not AllowedPlayers[player.Name] then
			return
		end

		msg = tostring(msg)

		if string.sub(msg,1,#PREFIX) ~= PREFIX then
			return
		end

		local cmd = string.sub(msg,#PREFIX + 1)

		if not COMMANDS[cmd] then
			return
		end

		ExecuteCommand(cmd,player.Name)
	end)
end

for _, player in ipairs(Players:GetPlayers()) do
	HookPlayer(player)
end

