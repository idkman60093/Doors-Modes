local Config = {
	Damage = 90,
	Cooldown = 50,
	TargetRoom = "56"
}

local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local currentRooms = workspace:WaitForChild("CurrentRooms")

local running = false
local detected = false

local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getHumanoid()
	local char = getCharacter()
	return char:FindFirstChildOfClass("Humanoid")
end

local function getMainGame()
	return playerGui:WaitForChild("MainUI")
		:WaitForChild("Initiator")
		:WaitForChild("Main_Game")
end

local function getRoom()
	local currentRoom = player:GetAttribute("CurrentRoom")
	if not currentRoom then return nil end
	return currentRooms:FindFirstChild(currentRoom)
end

local function isMoving()
	local hum = getHumanoid()
	if not hum then return false end
	return hum.MoveDirection.Magnitude > 0.05
end

local function dealDamage()
	local hum = getHumanoid()

	if hum and hum.Health > 0 then
		hum.Health = hum.Health - Config.Damage
	end
end

local function runA90()
	if running then
		return
	end

	running = true

	local mainGame = getMainGame()
	local room = getRoom()

	if not room then
		running = false
		return
	end

	local module = mainGame:WaitForChild("RemoteListener")
		:WaitForChild("Modules")
		:WaitForChild("A90")

	local ok, a90 = pcall(function()
		return require(module)
	end)

	if ok and typeof(a90) == "function" then
		a90(require(mainGame), room)
	end

	local triggered = false

	local startTime = os.clock()

	while os.clock() - startTime < 3 do
		task.wait()

		local gui = playerGui:FindFirstChild("MainUI")
		local jumpscare = gui and gui:FindFirstChild("Jumpscare")
		local a90Gui = jumpscare and jumpscare:FindFirstChild("Jumpscare_A90")

		local active = false

		if a90Gui then
			local face = a90Gui:FindFirstChild("FaceAngry")

			if face and face.Visible then
				active = true
			end
		end

		if active and isMoving() then
			triggered = true
			dealDamage()
			break
		end
	end

	task.wait(Config.Cooldown)

	running = false
end

local function startLoop()
	task.spawn(function()
		while detected do
			runA90()

			repeat
				task.wait()
			until not running
		end
	end)
end

local existing = currentRooms:FindFirstChild(Config.TargetRoom)

if existing then
	detected = true
	startLoop()
else
	local connection

	connection = currentRooms.ChildAdded:Connect(function(child)
		if child.Name == Config.TargetRoom then
			detected = true

			if connection then
				connection:Disconnect()
			end

			startLoop()
		end
	end)
end
