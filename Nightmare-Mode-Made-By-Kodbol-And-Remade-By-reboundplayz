local function _getGitAsset(url, fileName)
    if not isfile(fileName .. ".mp3") and string.find(fileName, ".mp3") then
        writefile(fileName .. ".mp3", game:HttpGet(url))
    elseif not isfile(fileName) then
        writefile(fileName, game:HttpGet(url))
    end

    local assetFunc = getcustomasset or getsynasset
    return assetFunc(string.find(fileName, ".mp3") and (fileName .. ".mp3") or fileName)
end

TextChatService.OnIncomingMessage = function(message)
    local properties = Instance.new("TextChatMessageProperties")

    if message.TextSource then
        local player = Players:GetPlayerByUserId(message.TextSource.UserId)

        if player then
            if player.Name == "kardindoorsgoat" then
                properties.PrefixText = "<font color='#FFD700'>[Owner]</font> " .. (message.PrefixText or "")
            elseif player.Name == "TestingDoorsScrip" then
                properties.PrefixText = "<font color='#00AAFF'>[Admin]</font><font color='#FFFFFF'> and </font><font color='#00FF00'>[Helper]</font> " .. (message.PrefixText or "")
            elseif player.Name == "DaviGamer_NovaConta" then
                properties.PrefixText = "<font color='#00AAFF'>[Admin]</font>" .. (message.PrefixText or "")
            elseif player.Name == "anbdnhucc" then
                properties.PrefixText = "<font color='#00FF00'>[Helper]</font> " .. (message.PrefixText or "")
            end
        end
    end

    return properties
end

