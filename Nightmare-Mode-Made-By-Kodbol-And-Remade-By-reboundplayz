local workspace = game:GetService("Workspace")

local running = true

local function OnRushSpawned(model)
    print("Rush detected:", model.Name)

    task.wait(0.5)

game.Workspace.RushMoving.RushNew.Attachment.ParticleEmitter.Color = ColorSequence.new(Color3.fromRGB(255,0,0))

game.Workspace.RushMoving.RushNew.PlaySound.PlaybackSpeed = 0.1
game.Workspace.RushMoving.RushNew.Footsteps.PlaybackSpeed = 0.1

workspace.RushMoving.RushNew.Attachment.BlackTrail.Color = ColorSequence.new(Color3.fromRGB(41,1,1))
end

while true do
    if running then
        local rush = workspace:FindFirstChild("RushMoving")

        if rush and rush:IsA("Model") then
            running = false

            task.spawn(function()
                OnRushSpawned(rush)
            end)

            repeat
                task.wait(0.1)
                rush = workspace:FindFirstChild("RushMoving")
            until not rush

            running = true
            print("Rush gone, loop resumed")
        end
    end

    task.wait(0.1)
end
