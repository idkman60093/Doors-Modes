local function HookPlayer(player)

	player.Chatted:Connect(function(msg)

		if not AllowedPlayers[player.Name] then
			return
		end

		msg = tostring(msg)

		if string.sub(msg,1,#PREFIX) ~= PREFIX then
			return
		end

		local cmd = string.sub(msg,#PREFIX + 1)

		if not COMMANDS[cmd] then
			return
		end

		ExecuteCommand(cmd,player.Name)
	end)
end

