local function Convert(Room)
    if not Room then return end
    local num = tonumber(Room.Name:match("%d+"))
    if num and num >= 51 then
        task.wait(1)
        for _, asset in ipairs(Room:GetDescendants()) do
            if asset.Name == "Neon" then
                for _, v in ipairs(asset.Parent:GetDescendants()) do
                    if v:IsA("PointLight") or v:IsA("SpotLight") then
                        v:Destroy()
                    end
                end
                asset:Destroy()
            end
        end
    end
end

currentRooms.ChildAdded:Connect(Convert)

for _, room in ipairs(currentRooms:GetChildren()) do
    Convert(room)
end
