print("Oof's Impossible Mode Script Loaded")

-- 1. Define services and LocalPlayer first so they can be used below
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- 2. Safely locate the MainGame module using your path
local MainGame = nil
local playerGui = LocalPlayer:WaitForChild("PlayerGui", 5)

if playerGui then
    local mainUI = playerGui:WaitForChild("MainUI", 5)
    if mainUI and mainUI:FindFirstChild("Initiator") and mainUI.Initiator:FindFirstChild("Main_Game") then
        MainGame = require(mainUI.Initiator.Main_Game)
    end
end

-- Fallback: If the path changes or isn't found, use a dummy to prevent crashes
if not MainGame then
    MainGame = {
        caption = function(text, color)
            print("[Caption Fallback]: " .. tostring(text))
        end
    }
end

-- 3. Run your initial caption now that MainGame is safely defined
MainGame.caption("Oof's Impossible Mode Script Executed", true)

-- 4. Wait for the game to start/room to change
ReplicatedStorage.GameData.LatestRoom.Changed:Wait()

coroutine.wrap(function()
    
    -- Using the MainGame variable we defined at the top cleanly
    MainGame.caption("Script sync'd according to the room", true)
    task.wait(2)
    MainGame.caption("Fixed entities by reboundplayz", true)
end)()

